# --- Server ---
NODE_ENV=production
PORT=4011

# --- Database ---
# Absolute path on the droplet. Keep this OUTSIDE the repo so deploys don't wipe it.
DATABASE_PATH=/var/www/adversarydata/data/jones.sqlite

# --- Session (iron-session) ---
# Must be at least 32 chars. Generate with: openssl rand -hex 32
SESSION_SECRET=replace-me-with-32-plus-random-chars-please-do
SESSION_COOKIE_NAME=advdata_sess

# --- First admin (only used by `npm run db:init` on a fresh DB) ---
ADMIN_EMAIL=rgj@rolandjones.com
ADMIN_PASSWORD=ChangeMeImmediately!
ADMIN_NAME=Roland G. Jones

# --- Public site ---
NEXT_PUBLIC_SITE_URL=https://adversarydata.com
NEXT_PUBLIC_SITE_NAME=Jones & Associates
